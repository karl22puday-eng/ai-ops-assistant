# AI Ops Assistant — environment template
# Copy to .env and fill. .env is gitignored — NEVER commit real keys.
# In n8n these live as Credentials; .env is the local reference.

# ── LLM ───────────────────────────────────────────────────────────────────────
# Groq chat model for the agent. In n8n use the Groq credential on the Groq Chat Model node.
GROQ_API_KEY=gsk_...

# ── Supabase (read-only sanitized views from projects #1 / #2) ────────────────
# The agent's data tools GET these with the ANON key (RLS-safe, no PII, read-only).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon key — read-only on leads_public / content_public>

# ── Google Sheets (stretch: invoices tool from project #3) ────────────────────
SHEET_ID=<google sheet id for "Invoice Ledger">
SHEET_TAB=Invoices

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://<your-workspace>.app.n8n.cloud
